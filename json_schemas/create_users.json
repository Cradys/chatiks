{  
  "$schema": "https://json-schema.org/draft-07/schema",  
  "$id": "auth",  
  "title": "Auth",  
  "description": "A product in the catalog",  
  "type": "object",
  "properties": {
    "body": {
      "type": "object",
      "properties": {
        "name": { "type": "string"},
        "login": { "type": "string" },
        "password": { "type": "string"},
        "phone_number": { "type": "string"}
      },
      "required": ["login", "password"],
      "additionalProperties": false
    }
  }
}